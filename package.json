{
  "name": "gotravel",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "vite build && esbuild api/_entry.ts --bundle --platform=node --target=node20 --format=esm --outfile=api/index.js --external:mysql2 --external:nodemailer --external:sharp --external:vite --external:lightningcss --external:vite-plugin-pwa --external:@vite-pwa --external:@vitejs --external:vite-plugin-manus-runtime --external:rollup --external:@tailwindcss",
    "vercel-build": "vite build && esbuild api/_entry.ts --bundle --platform=node --target=node20 --format=esm --outfile=api/index.js --external:mysql2 --external:nodemailer --external:sharp --external:vite --external:lightningcss --external:vite-plugin-pwa --external:@vite-pwa --external:@vitejs --external:vite-plugin-manus-runtime --external:rollup --external:@tailwindcss",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "optimize-images": "npx sharp-cli --input 'client/public/images/**/*.{jpg,png}' --output 'client/public/images/optimized/' --format avif --quality 80 && npx sharp-cli --input 'client/public/images/**/*.{jpg,png}' --output 'client/public/images/optimized/' --format webp --quality 82",
    "optimize-images:check": "ls -lh client/public/images/optimized/"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.8",
    "@tanstack/react-query": "^5.90.20",
    "@trpc/client": "^11.6.0",
    "@trpc/react-query": "^11.6.0",
    "@trpc/server": "^11.6.0",
    "amadeus": "^11.0.0",
    "axios": "^1.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "express": "^4.21.2",
    "framer-motion": "^12.34.3",
    "glob": "^13.0.6",
    "i18next": "^25.8.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "jose": "6.1.0",
    "lucide-react": "^0.453.0",
    "mysql2": "^3.15.0",
    "nanoid": "^5.1.5",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.2",
    "posthog-js": "^1.353.0",
    "react": "^19.2.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.1",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^16.5.4",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "streamdown": "^1.4.0",
    "superjson": "^1.13.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "web-vitals": "^5.1.0",
    "wouter": "^3.3.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@builder.io/vite-plugin-jsx-loc": "^0.1.1",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.3",
    "@playwright/test": "^1.42.1",
    "@types/express": "4.17.21",
    "@types/google.maps": "^3.58.1",
    "@types/i18next": "^13.0.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vercel/node": "^5.6.10",
    "@vitejs/plugin-react": "^5.0.4",
    "add": "^2.0.6",
    "autoprefixer": "^10.4.20",
    "@axe-core/cli": "^4.11.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.25.0",
    "pnpm": "^10.15.1",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "sharp": "^0.34.5",
    "sharp-cli": "5.2.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.19.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.2",
    "vite": "^7.1.7",
    "vite-plugin-manus-runtime": "^0.0.57",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "patchedDependencies": {
      "wouter@3.7.1": "patches/wouter@3.7.1.patch"
    },
    "overrides": {
      "tailwindcss>nanoid": "3.3.7"
    },
    "ignoredBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  }
}