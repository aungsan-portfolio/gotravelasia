{
    "installCommand": "pnpm install",
    "buildCommand": "pnpm build",
    "outputDirectory": "dist/public",
    "framework": null,
    "functions": {
        "api/price-alerts/subscribe.ts": {
            "maxDuration": 10,
            "includeFiles": "lib/**"
        },
        "api/newsletter.ts": {
            "maxDuration": 10
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/check-price-alerts",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/cron/send-alerts",
            "schedule": "5 8 * * *"
        }
    ]
}