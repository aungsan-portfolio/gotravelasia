{
    "installCommand": "pnpm install",
    "buildCommand": "pnpm build",
    "outputDirectory": "dist/public",
    "framework": null,
    "functions": {
        "api/price-alerts/subscribe.ts": {
            "maxDuration": 10
        },
        "api/newsletter.ts": {
            "maxDuration": 10
        },
        "api/destination-landing.ts": {
            "memory": 1024,
            "maxDuration": 15
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/check-price-alerts",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/cron/send-alerts",
            "schedule": "5 8 * * *"
        }
    ]
}