{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "framework": null,
  "functions": {
    "api/cron/check-price-alerts.ts": {
      "maxDuration": 60
    },
    "api/cron/send-alerts.ts": {
      "maxDuration": 60
    },
    "api/price-alerts/subscribe.ts": {
      "maxDuration": 10
    },
    "api/newsletter.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-price-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/send-alerts",
      "schedule": "30 8 * * *"
    }
  ]
}