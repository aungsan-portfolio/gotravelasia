# =========================================================
# GoTravel Asia â€” Local Environment Template
# Copy this file to .env.local and fill in real values.
# Never commit real secrets to Git.
# =========================================================

# =========================================================
# 1) App Mode
# =========================================================
# Development:
# NODE_ENV=development
#
# Production on Vercel:
# NODE_ENV=production
NODE_ENV=development

# Base URL
# Development:
# APP_BASE_URL=http://localhost:3000
#
# Production:
# APP_BASE_URL=https://gotravel-asia.vercel.app
APP_BASE_URL=http://localhost:3000

# Optional debug logging for hotel API
# Use true in development, usually false in production
ENABLE_HOTEL_DEBUG_META=true
LOG_LEVEL=debug

# =========================================================
# 2) Agoda Live Hotel Inventory (Server-side only)
# =========================================================
# Required for live Agoda hotel search in server/api/hotels.ts
# DO NOT use VITE_ prefix for these.
AGODA_SITE_ID=
AGODA_API_KEY=

# =========================================================
# 3) Booking.com via AWIN Deeplink Wrapping
# =========================================================
# Server-side only
AWIN_TOKEN=
AWIN_PUBLISHER_ID=
BOOKING_AWIN_ADV_ID=

# Awin integration options (optional, sensible defaults)
# AWIN_TIMEOUT_MS=5000
# AWIN_MAX_RETRIES=2

# =========================================================
# 4) Other Hotel / Affiliate Provider IDs
# =========================================================
# These are used for outbound links / partner routing
TRIP_COM_SITE_ID=
KLOOK_PARTNER_ID=
EXPEDIA_TP_CODE=

# Hotellook is a secondary fallback provider that is not production-ready.
# It is disabled by default; set to "true" only to register it in the
# provider orchestrator (server/api/hotels.ts).
HOTELS_ENABLE_HOTELLOOK=false

# =========================================================
# 5) Frontend-safe Public Variables
# =========================================================
# Only use VITE_ prefix for values that are safe to expose
# to the browser bundle.
#
# Example:
# VITE_SITE_URL=http://localhost:3000
# VITE_GOOGLE_CLIENT_ID=
#
# Production example:
# VITE_SITE_URL=https://gotravel-asia.vercel.app
VITE_SITE_URL=http://localhost:3000
VITE_GOOGLE_CLIENT_ID=

# =========================================================
# 6) Optional App / Platform Secrets
# =========================================================
# Fill only if your local setup needs them.
DATABASE_URL=
JWT_SECRET=
SENTRY_DSN=
VITE_SENTRY_DSN=
ALLOW_HOTEL_MOCKS=false
WEB3FORMS_KEY=
TWELVE_GO_API_KEY=

# =========================================================
# 7) Hotel Cache Configuration (optional)
# =========================================================
# L2 cache TTL for hotel search results (seconds). Default: 1800 (30 min)
# HOTEL_CACHE_TTL_SECONDS=1800
#
# L1 (process-local) cache TTL (ms). Default: 300000 (5 min)
# HOTEL_CACHE_L1_TTL_MS=300000
#
# Max L1 cache entries before eviction. Default: 200
# HOTEL_CACHE_L1_MAX_SIZE=200
#
# Upstash Redis / Vercel KV (shared store for L2 cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Alternative KV names (Vercel):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# =========================================================
# 7) Notes
# =========================================================
# Local development:
# - copy this file to .env.local
# - use localhost values
# - enable debug meta if needed
#
# Production:
# - do not upload .env.local
# - set real secrets in Vercel Environment Variables
# - set NODE_ENV=production
# - set APP_BASE_URL and VITE_SITE_URL to production domain
# =========================================================
# 8) Flight API Rate Limiting (optional)
# =========================================================
# Cap on /api/flights requests per minute per IP.
# Default: 60 (suitable for ~1 req/sec sustained)
# Increase for high-traffic deployments; decrease for stricter limits.
# Requires UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN above
# for cross-instance limiting. Without those, falls back to per-instance
# in-memory limiting (resets on Vercel cold start).
# RATE_LIMIT_FLIGHTS_PER_MIN=60
