# ═══════════════════════════════════════════════════════
# GoTravel Asia — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# ═══════════════════════════════════════════════════════

# ─── Server ───
PORT=3000
NODE_ENV=development

# ─── Amadeus Self-Service API (PRIMARY flight data) ───
# Get keys: https://developers.amadeus.com → Register → My Self-Service Workspace → API Keys
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here
AMADEUS_HOSTNAME=test

# ─── Travelpayouts / Aviasales (fallback flight data) ───
TRAVELPAYOUTS_TOKEN=your_travelpayouts_token_here

# ─── Gemini AI (Trip Planner) ───
GEMINI_API_KEY=your_gemini_api_key_here

# ─── PostHog Analytics ───
VITE_POSTHOG_KEY=your_posthog_key_here
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ─── Database (optional) ───
DATABASE_URL=mysql://user:password@host:3306/dbname

# ─── Auth (optional) ───
# JWT_SECRET=your_jwt_secret_here
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=
# VITE_APP_ID=

# ─── Google Sign-In ───
# Get Client ID from: https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
